{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account coordinates and details",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "country": { "type": "string" },
        "state": { "type": "string" },
        "city": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["uid"]
    },
    "Order": {
      "title": "Order",
      "description": "Keepsake order details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "imageUrl": { "type": "string" },
        "canvaLink": { "type": "string" },
        "siteUrl": { "type": "string" }
      },
      "required": ["id", "userId", "title", "price", "type", "category", "status", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Chat message between user and artisan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "sender": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "orderId", "sender", "senderName", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "User orders"
    },
    "/chats/{orderId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat messages for orders"
    }
  }
}
